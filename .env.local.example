# ==========================================
# Convex Environment Variables
# ==========================================
# Copy this file to .env.local and fill in your values
# Get these from your Convex dashboard: https://dashboard.convex.dev

# Deployment identifier from Convex dashboard
# Format: <project-name>-<random-string>
# Example: my-project-1a2b3c4d
CONVEX_DEPLOYMENT=

# Convex production URL
# Format: https://<convex-project>.convex.cloud
CONVEX_URL=

# Convex site URL (for production deployments)
# Format: https://<site-name>.convex.site
CONVEX_SITE_URL=
