# Automation Manuals local environment example
# Copy this file to `.env.local`, then fill in the values you actually need.
#
# Important:
# 1. Frontend/public values such as `CONVEX_URL` are read from `.env.local`.
# 2. Backend/server secrets used inside Convex functions are also read via `process.env`,
#    but for real Convex dev/prod deployments you should set them in:
#    - Convex Dashboard -> Deployment Settings -> Environment Variables
#    - or `npx convex env set NAME value`
# 3. Do not commit your real `.env.local`.

# ============================================================================
# Convex deployment connection
# ============================================================================
# What it is:
# - Connection info for the frontend and local development.
# How to get it:
# - Run `npx convex dev --configure` or `npx convex dev`
# - Convex will usually write `CONVEX_DEPLOYMENT` and `CONVEX_URL` for you.
# - If needed, copy URLs from Convex Dashboard -> Deployment Settings.
# Docs:
# - https://docs.convex.dev/production/project-configuration
# - https://docs.convex.dev/production/environment-variables

# Required for local development. Usually auto-written by `npx convex dev`.
# Example: witty-fox-123
CONVEX_DEPLOYMENT=

# Required by the frontend Convex client.
# Example: https://witty-fox-123.convex.cloud
CONVEX_URL=

# ============================================================================
# Admin console session auth
# ============================================================================
# What it is:
# - Minimal admin-only login for the `/admin` route.
# How to get it:
# - Pick a strong username.
# - Generate an Argon2id hash for the password with:
#   `node scripts/hash-admin-password.mjs "your-strong-password"`
# - Store only the generated hash below.

ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_TTL_MS=1800000


# ============================================================================
# MinerU Precision API
# ============================================================================
# What it is:
# - The document extraction provider used for PDF ingestion.
# How to get it:
# - Open MinerU API page: https://mineru.net/apiManage/token
# - Apply for / generate a Precision API token
# - Use the token as `MINERU_API_TOKEN`
# Docs:
# - https://mineru.net/apiManage/docs
# - https://mineru.net/doc/docs/
# - https://mineru.net/apiManage/limit

# Required. Precision API token.
MINERU_API_TOKEN=

# Optional but recommended when your Convex `.convex.site` URL is public.
# If blank, the app falls back to polling-only reconciliation.
# Example: https://witty-fox-123.convex.site/providers/mineru/callback
MINERU_CALLBACK_URL=

# Optional unless `MINERU_CALLBACK_URL` is set.
# This is your own random shared secret used to verify MinerU callbacks.
# Example: plc_manuals_mineru_callback_seed_2026
MINERU_CALLBACK_SEED=

# Optional unless `MINERU_CALLBACK_URL` is set.
# MinerU callback verification also needs your MinerU user UID.
# Get it from your MinerU personal center / account page, as described in the API docs.
# Example: 123456
MINERU_CALLBACK_UID=

# Optional tuning. Defaults shown here match the current codebase defaults.
MINERU_DAILY_PRIORITY_PAGES=1000
MINERU_DAILY_FILE_LIMIT=5000
MINERU_SUBMIT_RATE_PER_MINUTE=50
MINERU_RESULT_QUERY_RATE_PER_MINUTE=1000


# ============================================================================
# Mistral API
# ============================================================================
# What it is:
# - Used for embeddings and grounded answer generation.
# How to get it:
# - Create a Mistral account / workspace: https://console.mistral.ai
# - Activate the Studio / Experiment plan if needed
# - Generate an API key in Workspace Settings -> API Keys
# Docs:
# - https://docs.mistral.ai/getting-started/quickstarts/studio/activate-and-generate-api-key
# - https://docs.mistral.ai/api

# Required.
MISTRAL_API_KEY=

# Optional. Defaults to `mistral-small-latest` in this project.
MISTRAL_CHAT_MODEL=mistral-small-latest

# Optional. Defaults to `mistral-embed` in this project.
MISTRAL_EMBED_MODEL=mistral-embed
