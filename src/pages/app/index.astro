---
import Layout from "@/layouts/Layout.astro"

import AppShellIsland from "@widgets/app-shell/island"
---

<Layout title="Engineer Workspace | Navigineer">
  <AppShellIsland client:load title="Engineer Workspace">
    <section class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_minmax(0,0.8fr)]">
      <article class="rounded-3xl border border-slate-800 bg-slate-900/70 p-6 shadow-xl shadow-slate-950/30">
        <p class="text-xs font-semibold uppercase tracking-[0.4em] text-cyan-300">Protected shell</p>
        <h2 class="mt-3 text-2xl font-semibold text-white">Engineer workspace ready</h2>
        <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-300">
          This protected route is ready for the split-screen assistant, evidence viewer, and citation workflow that lands in the next task.
        </p>
      </article>

      <article class="rounded-3xl border border-slate-800 bg-slate-950/60 p-6">
        <p class="text-xs font-semibold uppercase tracking-[0.4em] text-slate-400">Upcoming panels</p>
        <ul class="mt-4 space-y-3 text-sm text-slate-300">
          <li class="rounded-2xl border border-slate-800 bg-slate-900/70 p-4">Answer composer</li>
          <li class="rounded-2xl border border-slate-800 bg-slate-900/70 p-4">Grounded answer packet</li>
          <li class="rounded-2xl border border-slate-800 bg-slate-900/70 p-4">Evidence viewer</li>
        </ul>
      </article>
    </section>
  </AppShellIsland>
</Layout>
